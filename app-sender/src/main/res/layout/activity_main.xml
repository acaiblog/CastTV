<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1EFE8"
    tools:context=".MainActivity">

    <!-- 顶部状态栏 -->
    <View
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#0C447C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <!-- 本机IP显示 -->
    <TextView
        android:id="@+id/tvLocalIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="本机IP：检测中…"
        android:textSize="12sp"
        android:textColor="#CCCCCC"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="24dp"/>

    <!-- 电视分辨率 -->
    <TextView
        android:id="@+id/tvResolution"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="电视分辨率：检测中…"
        android:textSize="14sp"
        android:textColor="#5F5E5A"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <!-- 电视设备列表 -->
    <TextView
        android:id="@+id/tvDevicesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_tv"
        android:textSize="16sp"
        android:textColor="#2C2C2A"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvResolution"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDevices"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvDevicesLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvNoDevices"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_tv_found"
        android:textSize="14sp"
        android:textColor="#888780"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvDevices"
        app:layout_constraintBottom_toBottomOf="@id/rvDevices"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 日志区域 -->
    <TextView
        android:id="@+id/tvLogLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 调试日志"
        android:textSize="12sp"
        android:textColor="#666666"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/rvDevices"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:background="#2C2C2A"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLogLabel"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:text=""
            android:lineSpacingExtra="2dp"/>
    </ScrollView>

    <!-- 状态显示 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textSize="13sp"
        android:textColor="#888780"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartCast"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <!-- 刷新按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRefresh"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="刷新"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/tvStatus"
        app:layout_constraintBottom_toBottomOf="@id/tvStatus"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="24dp"/>

    <!-- 投屏按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartCast"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_start_cast"
        android:textSize="16sp"
        app:backgroundTint="#185FA5"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
